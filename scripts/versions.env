# 必选（脚本会 source 本文件，因此必须是 bash 变量赋值语法）
MYSQL_SERIES="MySQL-8.4"     # 推荐 8.4 LTS
MYSQL_VER="8.4.9"
MYSQL_OS="33"               # macOS
REDIS_VER="7.2.5"
# 迁移工具（golang-migrate）
# CLI: https://github.com/golang-migrate/migrate/releases
# 我们只使用官方发布的二进制（不依赖 brew）。
MIGRATE_CLI="migrate"            # 固定为 migrate
MIGRATE_VER="4.17.1"             # golang-migrate CLI 版本（建议锁定）
# 可选：锁定 SHA256（企业推荐，避免供应链风险；留空则不校验）
MIGRATE_SHA256_DARWIN_ARM64=""
MIGRATE_SHA256_DARWIN_AMD64=""

# 安装位置约定：
# - 二进制：./.dev/bin/${MIGRATE_CLI}
# - migrations 目录：./migrations

# 可选
MINIO_VER="latest"          # 用目录 latest（脚本会取最新文件名）
KAFKA_VER="3.7.0"
JDK_MAJOR="21"              # Kafka 用 JDK 21 LTS（Oracle/Temurin 都可）
JAEGER_VER="2.14.1"

# 可选：手动固定 MySQL DMG 直链（留空则脚本自动解析真实文件名，避免 404）
# MYSQL_MAC_URL="https://dev.mysql.com/get/Downloads/MySQL-8.4/mysql-8.4.8-macosXX-arm64.dmg"
MYSQL_MAC_URL=""

CURL_EXTRA_OPTS="--proxy http://127.0.0.1:29758"